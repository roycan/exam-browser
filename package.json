{
  "name": "exam-browser",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.roycan.exambrowser", 
    "productName": "KHub Exam Browser",
    "files": [
      "main.js",
      "package.json",
      "assets/**/*",
      "preload.js"
    ],
    "win": {
      "target": ["portable", "nsis"],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "directories": {
      "buildResources": "assets"
    }
  },
  "keywords": [],
  "author": "Roy Canseco",
  "license": "ISC",
  "description": "Locked Moodle exam browser for PSHS-KHub",
  "devDependencies": {
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1"
  }
}
